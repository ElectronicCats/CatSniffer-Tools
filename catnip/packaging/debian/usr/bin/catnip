#!/usr/bin/env python3

import os
import sys
import catnip

# Add vendor directory to sys.path for bundled dependencies
# This allows 'import meshtastic' to work when it's vendored into the package
vendor_path = os.path.join(os.path.dirname(catnip.__file__), "vendor")
if os.path.exists(vendor_path):
    sys.path.insert(0, vendor_path)

# Internal
from catnip.modules.cli import main_cli

if __name__ == "__main__":
    main_cli()
